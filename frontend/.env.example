# Frontend dev defaults (Vite)
# IMPORTANT: Use a full URL here, otherwise the frontend will call the Vite dev server (/api)
# and you may see: "Unexpected token '<' ... is not valid JSON" (HTML response).
VITE_BACKEND_URL=http://127.0.0.1:8000
VITE_API_URL=http://127.0.0.1:8000/api

# Optional: if you set `VITE_API_URL=/api` in production (Vercel rewrite proxy),
# you can set a direct fallback URL here to bypass proxy 502/503/504.
# Example: https://api.example.com/api
# VITE_API_FALLBACK_URL=
